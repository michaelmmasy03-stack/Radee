{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A juice or smoothie item on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Cold Pressed", "Smoothies", "Wellness Shots", "Protein Shakes"] },
        "image": { "type": "string" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "isSpecial": { "type": "boolean" }
      },
      "required": ["name", "description", "price", "category"]
    },
    "User": {
      "title": "User",
      "description": "Customer profile and loyalty info",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["displayName", "email", "role", "loyaltyPoints"]
    }
  },
  "firestore": {
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "The shop menu"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and loyalty accounts"
    }
  }
}
